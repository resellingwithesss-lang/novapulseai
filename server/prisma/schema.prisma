generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

///////////////////////////////////////////////////////
// ENUMS
///////////////////////////////////////////////////////

/// Authority / security-principal axis. Distinct from `Plan` (commercial
/// entitlement) and from `PlanGrant` (sponsored/staff-floor access).
///
/// Phase A adds OWNER and CREATOR without retiring USER or SUPER_ADMIN:
///   - no rows are migrated in this phase
///   - no code reads from OWNER or CREATOR yet
/// Phase B will:
///   - remap SUPER_ADMIN rows to OWNER (1:1)
///   - remap active USER rows to CREATOR (last active 180d OR has product
///     activity via Usage/Generation/EmailDelivery/Workspace)
///   - leave dormant/ghost accounts at USER as the new baseline
/// SUPER_ADMIN is kept as a deprecated alias in code for one release cycle,
/// then removed in Phase E.
enum Role {
  USER
  CREATOR
  ADMIN
  OWNER
  /// @deprecated Use OWNER. Preserved for a single release cycle to keep
  /// existing code paths (`requireSuperAdmin`, `AuditAction.ADMIN_IMPERSONATION_*`)
  /// working during the rename. Do not grant to new accounts.
  SUPER_ADMIN
}

enum Plan {
  FREE
  STARTER
  PRO
  ELITE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  PAUSED
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
}

enum CreditType {
  CREDIT_ADD
  CREDIT_USE
  REFUND
  ADMIN_ADJUSTMENT
  BONUS
  PROMOTION
  MONTHLY_RESET
  PLAN_UPGRADE
}

enum GenerationType {
  VIDEO
  STORY
  VIDEO_BLUEPRINT
}

enum UsageTool {
  VIDEO
  STORY
  IMAGE
  VIDEO_BLUEPRINT
}

enum AuditAction {
  USER_CREATED
  USER_DELETED
  USER_BANNED
  PLAN_CHANGED
  SUBSCRIPTION_UPDATED
  CREDITS_ADDED
  CREDITS_USED
  CREDITS_RESET
  LOGIN_SUCCESS
  LOGIN_FAILED
  PASSWORD_RESET
  STRIPE_EVENT_PROCESSED
  GENERATION_CREATED
  REFERRAL_COMMISSION_RECORDED
  ADMIN_IMPERSONATION_START
  ADMIN_IMPERSONATION_END
  MARKETING_CONSENT_CHANGED
  MARKETING_SUBSCRIBER_EXPORTED
}

/// Explicit lifecycle-marketing consent state. `LEGACY_OPT_IN` is a migration
/// backfill for users created before explicit consent capture; the fan-out treats
/// it as sendable until the user is re-prompted and answers explicitly.
enum MarketingConsentStatus {
  UNKNOWN
  OPTED_IN
  OPTED_OUT
  DISMISSED
  LEGACY_OPT_IN
}

/// Automated lifecycle email streams (fired by the engine, not by admins).
/// Adding a value here requires a matching `lifecycle-triggers.ts` registration,
/// a template in `marketing-templates.ts`, and a short migration.
enum LifecycleTrigger {
  CREDIT_EXHAUSTION_UPGRADE
  TRIAL_ENDING_REMINDER
  INACTIVE_USER_REACTIVATION
  ELITE_FEATURE_PROMOTION
  REFERRAL_PUSH
}

enum ReferralCommissionStatus {
  PENDING
  APPROVED
  PAID
  VOID
}

enum ContentPackStatus {
  DRAFT
  READY
  FAILED
}

enum EmailLogType {
  TRANSACTIONAL
  MARKETING
}

enum EmailLogStatus {
  SENT
  FAILED
}

enum EmailDeliveryStatus {
  QUEUED
  SENDING
  SENT
  FAILED
}

enum EmailCampaignStatus {
  DRAFT
  /// Queued for a future wall-clock send; promoted by `processScheduledCampaignsTick`.
  SCHEDULED
  QUEUED
  SENDING
  COMPLETED
  FAILED
}

///////////////////////////////////////////////////////
// USER
///////////////////////////////////////////////////////

model User {
  id String @id @default(uuid())

  email         String
  password      String?
  provider      AuthProvider @default(LOCAL)
  displayName   String?

  /// UI + workflow defaults (JSON). Keys: defaultBrandVoiceId, defaultWorkspaceId, uiDensity, emailProductUpdates, emailUsageAlerts
  preferences Json @default("{}")

  emailVerified Boolean @default(false)

  /// Product / broadcast email opt-in (separate from preferences.emailProductUpdates UI toggles).
  /// New signups default to `false` and must opt in via the consent surfaces
  /// (dashboard banner, settings, billing card). Historical users were backfilled
  /// to LEGACY_OPT_IN by the 20260419_marketing_consent_foundation migration and
  /// keep `marketingEmails=true` until they change it.
  marketingEmails           Boolean   @default(false)
  marketingUnsubscribeToken String    @unique @default(uuid())
  lastEmailSentAt           DateTime?

  /// Lifecycle marketing consent state. Fan-out only sends to OPTED_IN and
  /// LEGACY_OPT_IN (and ONLY when marketingEmails=true). See MarketingConsentStatus.
  marketingConsentStatus     MarketingConsentStatus @default(UNKNOWN)
  /// Surface that captured the most recent explicit consent answer.
  /// Known values: 'onboarding' | 'dashboard_banner' | 'billing_card' | 'settings'
  ///              | 'signup' | 'unsubscribe' | 'email_link' | 'admin'.
  marketingConsentSource     String?
  /// First time the user gave an explicit answer (opt-in OR opt-out).
  marketingConsentCapturedAt DateTime?
  /// Every subsequent explicit change.
  marketingConsentUpdatedAt  DateTime?
  /// Temporary "not right now" dismissal; banner re-surfaces after a cool-down.
  marketingDismissedAt       DateTime?
  /// Separate from `lastEmailSentAt` (transactional+marketing) so ops can tell
  /// whether a user received any marketing touch in the last N days.
  lastMarketingEmailSentAt   DateTime?

  role Role @default(USER)

  plan               Plan               @default(FREE)
  subscriptionStatus SubscriptionStatus @default(CANCELED)

  credits        Int       @default(4)
  monthlyCredits Int       @default(0)
  monthlyResetAt DateTime?

  lifetimeCreditsUsed Int @default(0)
  bonusCredits        Int @default(0)

  tokenVersion Int @default(0)

  loginAttempts Int       @default(0)
  lockUntil     DateTime?

  banned        Boolean @default(false)
  bannedReason String?

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  trialExpiresAt        DateTime?
  /// Set once Stripe confirms a PRO subscription (trial or paid); blocks future PRO-monthly checkout trials.
  billingProTrialConsumedAt DateTime?

  subscriptionStartedAt DateTime?
  subscriptionEndsAt    DateTime?
  cancelAtPeriodEnd     Boolean @default(false)

  /// Stripe SubscriptionSchedule id when a downgrade is deferred to period end (Stripe source of truth).
  stripeSubscriptionScheduleId String?
  /// App tier the subscription will move to after `scheduledPlanEffectiveAt` (UX + reconciliation).
  scheduledPlanTarget      Plan?
  /// `monthly` | `yearly` — matches request body `billing` for the pending change.
  scheduledPlanBilling     String?
  /// Unix-aligned period end when the scheduled downgrade takes effect (from Stripe subscription).
  scheduledPlanEffectiveAt DateTime?

  lastLoginAt   DateTime?
  lastActiveAt  DateTime?
  lastIpAddress String?
  lastUserAgent String?

  deletedAt DateTime?

  totalTokensUsed  Int     @default(0)
  totalAiCostUsd   Decimal @default(0.00) @db.Decimal(12,4)
  lifetimeValueUsd Decimal @default(0.00) @db.Decimal(12,4)

  totalGenerations Int @default(0)

  /// Uppercase A–Z / 2–9 style code for referral links (lazy-assigned on first affiliate page load if null).
  referralCode String? @unique
  referredByUserId String?
  referredBy       User?   @relation("UserReferralTree", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referredUsers    User[]  @relation("UserReferralTree")

  referralEarnings ReferralCommission[] @relation("ReferralCommissionReferrer")
  referralAsBuyer  ReferralCommission[] @relation("ReferralCommissionReferee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creditTransactions CreditTransaction[]
  generations        Generation[]
  usages             Usage[]
  rateLimits         RateLimitLog[]
  auditLogs          AuditLog[]
  adJobs             AdJob[]
  media              MediaAsset[]
  workspaces         Workspace[]
  brandVoices        BrandVoice[]
  contentPacks       ContentPack[]

  emailLogs       EmailLog[]
  emailDeliveries EmailDelivery[]
  emailCampaigns  EmailCampaign[] @relation("EmailCampaignCreator")
  lifecycleSends  LifecycleSend[]

  /// Sponsored / staff / partner / make-good plan access. Read-only in Phase A
  /// (no code branches on this yet). Phase C will wire it into
  /// `getEffectiveEntitlements()`; until then this is pure audit substrate.
  planGrants        PlanGrant[] @relation("PlanGrantRecipient")
  planGrantsIssued  PlanGrant[] @relation("PlanGrantGranter")
  planGrantsRevoked PlanGrant[] @relation("PlanGrantRevoker")

  @@unique([email, provider])
  @@index([email])
  @@index([referredByUserId])
  @@index([marketingConsentStatus])
  @@index([marketingEmails, marketingConsentStatus])
}

///////////////////////////////////////////////////////
// REFERRALS / AFFILIATE
///////////////////////////////////////////////////////

model ReferralCommission {
  id String @id @default(cuid())

  referrerUserId String
  referrer       User   @relation("ReferralCommissionReferrer", fields: [referrerUserId], references: [id], onDelete: Cascade)

  refereeUserId String
  referee       User   @relation("ReferralCommissionReferee", fields: [refereeUserId], references: [id], onDelete: Cascade)

  stripeInvoiceId String @unique
  stripeEventId   String?

  currency String @default("gbp")
  invoiceAmountMinor Int
  commissionRateBps  Int @default(500)
  commissionAmountMinor Int

  plan Plan?

  status ReferralCommissionStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referrerUserId])
  @@index([refereeUserId])
  @@index([status])
  @@index([createdAt])
}

///////////////////////////////////////////////////////
// EMAIL (transactional + marketing queue + audit)
///////////////////////////////////////////////////////

model EmailLog {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  type    EmailLogType
  subject String
  status  EmailLogStatus

  errorMessage String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model EmailCampaign {
  id String @id @default(cuid())

  name    String
  subject String
  /// Full HTML body (admin-composed); links should use PUBLIC_APP_URL.
  htmlContent String @db.Text

  status EmailCampaignStatus @default(DRAFT)

  /// When set and status is SCHEDULED, fan-out starts after this instant (UTC).
  scheduledSendAt DateTime?

  /// Optional filter snapshot: { plan?: Plan, subscriptionStatus?: SubscriptionStatus }
  filter Json?

  queuedCount Int @default(0)
  sentCount   Int @default(0)
  failedCount Int @default(0)

  createdByUserId String?
  createdBy       User?   @relation("EmailCampaignCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  sentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries EmailDelivery[]

  @@index([status, createdAt])
}

model EmailDelivery {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  campaignId String?
  campaign   EmailCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  toEmail String
  subject String
  html    String @db.Text

  kind   EmailLogType
  status EmailDeliveryStatus @default(QUEUED)

  attempts  Int     @default(0)
  lastError String?

  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([status, createdAt])
  @@index([campaignId])
}

/// Reason code for a sponsored / off-Stripe plan grant. Kept as an enum so
/// reporting and compliance queries ("how many COMP grants active right now?")
/// stay machine-readable. Add new reasons here; never overload `OTHER` for
/// things that deserve their own audit bucket.
enum PlanGrantReason {
  /// Active employee / contractor access.
  STAFF
  /// Strategic partner, investor, or advisory access.
  PARTNER
  /// Complimentary access for marketing, PR, creator collabs.
  COMP
  /// Time-boxed promotion (launches, events, PR pushes).
  PROMO
  /// Make-good for a billing bug / outage / support-resolved incident.
  BUG_MAKEGOOD
  /// Beta / preview access to a feature gated by plan.
  BETA
  /// Fall-through for cases that will be promoted to their own reason later.
  OTHER
}

/// Sponsored / off-Stripe plan grant. **Stripe remains the single source of
/// truth for billable subscription state** (`User.plan`, `subscriptionStatus`,
/// `subscriptionStartedAt`, `trialExpiresAt`). PlanGrant is a parallel,
/// time-bounded, auditable override used by `getEffectiveEntitlements()` to
/// compute effective access without ever mutating Stripe-owned columns.
///
/// Resolution rule (Phase C, not yet active):
///   effectivePlan = MAX(
///     stripeDerivedPlan(user.plan, user.subscriptionStatus),
///     highest-ranked active PlanGrant,
///     staff-floor from role,
///   )
///
/// Active = (startsAt <= now) AND (endsAt IS NULL OR endsAt > now) AND (revokedAt IS NULL).
///
/// Invariants:
///   - never updated after create except via revoke (revokedAt + revokedByUserId);
///     extensions create a new grant row
///   - `grantedByUserId` must be a user whose role is OWNER at the time of create
///     (enforced at the service layer — Prisma has no cross-row role constraint)
///   - `plan` is the plan level granted, NOT a modifier on top of Stripe plan;
///     `getEffectiveEntitlements` takes the MAX, it does not add
model PlanGrant {
  id     String @id @default(cuid())

  userId String
  user   User   @relation("PlanGrantRecipient", fields: [userId], references: [id], onDelete: Cascade)

  plan   Plan
  reason PlanGrantReason

  /// Free-text justification captured at grant time (e.g. Linear ticket #, a
  /// partner company name). Required for compliance reviewability; the enum
  /// reason alone is not sufficient for a post-hoc audit.
  note   String?

  /// OWNER who issued the grant. FK intentionally — if the owner is deleted
  /// we keep the grant (SetNull) because compliance needs the historical trail.
  grantedByUserId String?
  grantedBy       User?   @relation("PlanGrantGranter", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  /// Grant window. `endsAt` null = open-ended (STAFF floor, indefinite PARTNER).
  startsAt DateTime  @default(now())
  endsAt   DateTime?

  /// Revocation is separate from expiry. A revoked grant was explicitly pulled
  /// back (e.g. employee departed); an expired grant ran its natural course.
  /// Distinguishing these matters for audit + analytics.
  revokedAt       DateTime?
  revokedByUserId String?
  revokedBy       User?     @relation("PlanGrantRevoker", fields: [revokedByUserId], references: [id], onDelete: SetNull)
  revokedReason   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Hot-path: "is this user entitled via any active grant right now?"
  @@index([userId, revokedAt, endsAt])
  /// Compliance reporting: "all currently active STAFF grants".
  @@index([reason, revokedAt, endsAt])
  /// Audit: "grants issued by a specific owner".
  @@index([grantedByUserId])
}

/// Per-(user, trigger) record of an automated lifecycle send. The engine
/// writes this row inside the same transaction that enqueues the EmailDelivery,
/// so the row's existence is authoritative dedup for cooldown windows and the
/// only source of truth for "did this user already receive this trigger".
///
/// Admin surfaces read this table to produce per-trigger observability; do
/// NOT reuse EmailCampaign for lifecycle tracking — campaigns are finite
/// admin-created artifacts, lifecycle streams are continuous.
model LifecycleSend {
  id       String           @id @default(cuid())
  userId   String
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  trigger  LifecycleTrigger
  sentAt   DateTime         @default(now())
  /// Soft link to the queued delivery row. Nullable because we keep the
  /// LifecycleSend even if the EmailDelivery is later pruned.
  emailDeliveryId String?
  /// Small JSON payload capturing the values used to render the message
  /// (credits remaining, trial days left, etc.) for audit + debugging.
  metadata Json?

  @@index([userId, trigger, sentAt])
  @@index([trigger, sentAt])
  @@index([sentAt])
}

///////////////////////////////////////////////////////
// CREATOR WORKFLOW (workspaces, brand, packs)
///////////////////////////////////////////////////////

model Workspace {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name             String
  niche            String   @default("")
  targetAudience   String   @default("")
  primaryPlatforms String[] @default([])
  contentGoals     String[] @default([])
  defaultCtaStyle  String   @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brandVoices  BrandVoice[]
  contentPacks ContentPack[]
  generations  Generation[]
  adJobs       AdJob[]

  @@index([userId])
}

model BrandVoice {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  name                    String
  tone                    String   @default("")
  pacing                  String   @default("")
  slangLevel              String   @default("")
  ctaStyle                String   @default("")
  bannedPhrases           Json     @default("[]")
  audienceSophistication  String   @default("")
  notes                   String   @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contentPacks ContentPack[]
  generations  Generation[]

  @@index([userId])
  @@index([workspaceId])
}

model ContentPack {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  brandVoiceId String?
  brandVoice   BrandVoice? @relation(fields: [brandVoiceId], references: [id], onDelete: SetNull)

  title       String
  topic       String
  platform    String
  audience    String             @default("")
  payloadJson Json
  status      ContentPackStatus @default(READY)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourcedGenerations Generation[]
  sourcedAdJobs      AdJob[]

  @@index([userId])
  @@index([workspaceId])
  @@index([createdAt])
}

///////////////////////////////////////////////////////
// MEDIA STORAGE
///////////////////////////////////////////////////////

model MediaAsset {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type String

  url      String
  fileSize Int?

  width  Int?
  height Int?

  durationMs Int?

  createdAt DateTime @default(now())

  @@index([userId])
}

///////////////////////////////////////////////////////
// CREDIT TRANSACTIONS
///////////////////////////////////////////////////////

model CreditTransaction {
  id String @id @default(uuid())

  userId String
  amount Int
  type   CreditType
  reason String

  requestId String?
  metadata  Json?

  balanceAfter Int?
  ipAddress    String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

///////////////////////////////////////////////////////
// GENERATIONS
///////////////////////////////////////////////////////

model Generation {
  id String @id @default(cuid())

  userId String
  type   GenerationType

  input  String
  output String

  creditsUsed   Int
  tokensUsed    Int?
  estimatedCost Decimal? @db.Decimal(12,4)

  requestId String?

  modelUsed  String?
  durationMs Int?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  brandVoiceId String?
  brandVoice   BrandVoice? @relation(fields: [brandVoiceId], references: [id], onDelete: SetNull)

  sourceContentPackId String?
  sourceContentPack   ContentPack? @relation(fields: [sourceContentPackId], references: [id], onDelete: SetNull)

  sourceGenerationId String?
  sourceGeneration   Generation?  @relation("GenerationLineage", fields: [sourceGenerationId], references: [id], onDelete: SetNull)
  derivedGenerations Generation[] @relation("GenerationLineage")

  sourceType String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([brandVoiceId])
  @@index([sourceContentPackId])
  @@index([sourceGenerationId])
}

///////////////////////////////////////////////////////
// AD JOB SYSTEM
///////////////////////////////////////////////////////

model AdJob {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  sourceContentPackId String?
  sourceContentPack   ContentPack? @relation(fields: [sourceContentPackId], references: [id], onDelete: SetNull)

  sourceGenerationId String?
  sourceType           String?

  jobId String @unique

  status   String
  platform String
  duration Int
  tone     String

  progress Int @default(0)

  outputUrl    String?
  thumbnailUrl String?

  script    Json?
  scenePlan Json?
  voicePath String?

  renderStartedAt   DateTime?
  renderCompletedAt DateTime?

  workerId String?

  approved Boolean @default(true)
  archived Boolean @default(false)

  autoPostEnabled Boolean @default(false)
  published       Boolean @default(false)

  manuallyReviewed Boolean @default(false)

  refunded Boolean @default(false)

  isPrimary Boolean @default(false)

  views         Int @default(0)
  likes         Int @default(0)
  comments      Int @default(0)
  shares        Int @default(0)
  clickThroughs Int @default(0)

  fileSizeBytes Int?

  resolution  String?
  aspectRatio String?

  renderDurationMs Int?
  audioDurationMs  Int?

  sceneCount Int?

  creditsUsed Int?

  aiCostUsd     Decimal? @db.Decimal(12,4)
  renderCostUsd Decimal? @db.Decimal(12,4)
  totalCostUsd  Decimal? @db.Decimal(12,4)

  retryCount Int @default(0)

  failedReason String?

  requestId String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants AdVariant[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([workspaceId])
  @@index([sourceContentPackId])
}

///////////////////////////////////////////////////////
// AD VARIANTS
///////////////////////////////////////////////////////

model AdVariant {
  id String @id @default(cuid())

  adJobId String
  adJob   AdJob  @relation(fields: [adJobId], references: [id], onDelete: Cascade)

  variantIndex Int
  score        Int?

  script Json?

  voicePath String?
  videoPath String?

  thumbnailUrl String?

  approved Boolean @default(false)

  views       Int @default(0)
  clicks      Int @default(0)
  conversions Int @default(0)

  createdAt DateTime @default(now())

  @@index([adJobId])
}

///////////////////////////////////////////////////////
// USAGE
///////////////////////////////////////////////////////

model Usage {
  id String @id @default(uuid())

  userId String
  tool   UsageTool

  credits Int

  tokensUsed    Int?
  estimatedCost Decimal? @db.Decimal(12,4)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

///////////////////////////////////////////////////////
// RATE LIMIT LOG
///////////////////////////////////////////////////////

model RateLimitLog {
  id String @id @default(uuid())

  userId    String?
  endpoint  String
  ipAddress String?

  blocked Boolean @default(false)

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([endpoint])
}

///////////////////////////////////////////////////////
// STRIPE EVENTS
///////////////////////////////////////////////////////

model StripeEvent {
  id String @id @default(uuid())

  stripeEventId String @unique
  type          String

  processed Boolean @default(false)

  createdAt DateTime @default(now())
}

///////////////////////////////////////////////////////
// AUDIT LOG
///////////////////////////////////////////////////////

model AuditLog {
  id String @id @default(uuid())

  userId String?

  action   AuditAction
  metadata Json?

  requestId String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}