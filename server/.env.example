DATABASE_URL="postgresql://postgres:postgres@localhost:5432/novapulseai"

NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
# Optional comma-separated extra browser origins allowed in production CORS (staging, preview URLs).
# ALLOWED_ORIGINS=https://staging.example.com,https://preview.example.com
# Optional override for JSON body size (default 2mb). Large payloads rarely needed; raise only if required.
# JSON_BODY_LIMIT=2mb

JWT_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_strong_random_refresh_secret

# Set to 1 while debugging POST /api/auth/google (logs request shape only — never logs token values).
# DEBUG_GOOGLE_AUTH=1

# Web OAuth client (same value as NEXT_PUBLIC_GOOGLE_CLIENT_ID in client/.env*).
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs (Web application).
# Authorized JavaScript origins must include your app origin, e.g. http://localhost:3000 and http://127.0.0.1:3000
GOOGLE_CLIENT_ID=replace_with_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

OPENAI_API_KEY=replace_with_openai_api_key

STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret
STRIPE_PRICE_STARTER_MONTHLY=replace_with_stripe_price_id
STRIPE_PRICE_STARTER_YEARLY=replace_with_stripe_price_id
STRIPE_PRICE_PRO_MONTHLY=replace_with_stripe_price_id
STRIPE_PRICE_PRO_YEARLY=replace_with_stripe_price_id
STRIPE_PRICE_ELITE_MONTHLY=replace_with_stripe_price_id
STRIPE_PRICE_ELITE_YEARLY=replace_with_stripe_price_id

# PRO **monthly** checkout trial only (days). Unset defaults to 14. Set to 0 to disable checkout trials (Stripe Dashboard trial settings are not used).
# STRIPE_PRO_TRIAL_DAYS=14

# Optional: written into Stripe subscription/checkout metadata as "environment" (defaults to NODE_ENV).
# BILLING_ENVIRONMENT=production

# Client trial/marketing copy: set NEXT_PUBLIC_STRIPE_PRO_TRIAL_DAYS in client/.env.example to match STRIPE_PRO_TRIAL_DAYS.

# NovaPulseAI cinematic ads: both must be set to enable the logged-in demo arc (real sign-in + submit during capture). Omit to stay on public pages only.
AD_DEMO_EMAIL=replace_with_demo_email
AD_DEMO_PASSWORD=replace_with_demo_password

# Local NovaPulseAI monorepo: when generating ads against the dev client (http://localhost:3000), enable tuned capture on loopback.
# Applies only to localhost / 127.0.0.1 / ::1 — production novapulseai.* hosts ignore this. Set false if you use this .env for a different local site.
AD_TREAT_LOCALHOST_AS_NOVAPULSEAI=true

# --- Production / Docker (see docs/PRODUCTION.md) ---
# NODE_ENV=production
# TRUST_PROXY_HOPS=1
# AUTH_COOKIE_SAMESITE=lax
# When Next.js is on a different site than the API (e.g. Vercel + Railway), use: AUTH_COOKIE_SAMESITE=none (HTTPS required).
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_EXTRA_CHROMIUM_ARGS=
# PUBLIC_APP_URL=https://app.example.com
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# GIT_REVISION=optional-for-/health

# --- Affiliate / referrals (optional)
# Commission = invoice.amount_paid (Stripe minor units) * (REFERRAL_COMMISSION_RATE_BPS / 10000).
# Default: 500 bps = 5%. First qualifying paid invoice per referee unless disabled below.
# REFERRAL_COMMISSION_RATE_BPS=500
# REFERRAL_FIRST_PAYMENT_ONLY=true
#
# Shown in the user affiliate dashboard (mailto). Do not hardcode personal emails in source.
# OWNER_CONTACT_EMAIL=
# AFFILIATE_SUPPORT_EMAIL=
# ADMIN_NOTIFICATION_EMAIL=
