{
  "name": "novapulseai-server",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "start:prod": "prisma migrate deploy && node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "migrate:deploy": "prisma migrate deploy",
    "verify:adjob-schema": "node -r ts-node/register scripts/verify-adjob-lineage-columns.ts",
    "smoke:adjob-create": "node -r ts-node/register scripts/smoke-adjob-happy-path.ts",
    "smoke:ads-api:dev": "node -r ts-node/register scripts/dev-smoke-admin-ads-api.ts",
    "test:ads": "node -r ts-node/register --test src/tests/ads/ad-job-create-fallback.test.ts",
    "test:monetization": "node -r ts-node/register --test src/tests/monetization/plan-core.test.ts src/tests/monetization/access-safety.test.ts src/tests/monetization/frontend-backend-parity.test.ts",
    "test:workflow": "node -r ts-node/register --test src/tests/workflow/workflow-limits.test.ts src/tests/workflow/activity-serialization.test.ts src/tests/workflow/source-metadata.test.ts src/tests/workflow/creator-context-brand-voice.test.ts src/tests/workflow/content-pack-schema.test.ts",
    "test:auth": "node -r dotenv/config -r ts-node/register --test src/tests/auth/google-auth-hardening.test.ts"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.13.6",
    "bcryptjs": "3.0.3",
    "bottleneck": "^2.19.5",
    "chroma-js": "^3.2.0",
    "compression": "^1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "google-auth-library": "10.5.0",
    "helmet": "8.1.0",
    "hpp": "0.2.3",
    "jsonwebtoken": "9.0.3",
    "morgan": "1.10.1",
    "multer": "^2.1.1",
    "openai": "^6.22.0",
    "p-limit": "^7.3.0",
    "pg": "^8.18.0",
    "puppeteer": "^24.39.0",
    "sharp": "^0.34.5",
    "stripe": "^20.3.1",
    "uuid": "13.0.0",
    "youtube-transcript": "1.2.1",
    "yt-dlp-exec": "^1.0.2",
    "zod": "^4.3.6",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "^4.17.25",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/hpp": "0.2.7",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "1.9.7",
    "@types/multer": "^2.0.12",
    "@types/node": "^20",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}