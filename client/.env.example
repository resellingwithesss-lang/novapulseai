# Copy to .env.local for local Next.js. Production: set these in Vercel/host env (never commit secrets).

# Required for production build (see client/next.config.js)
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace_with_same_value_as_server_GOOGLE_CLIENT_ID

# Stripe price IDs (marketing / pricing UI). Checkout still uses server-side STRIPE_PRICE_* only.
# NEXT_PUBLIC_STRIPE_PRICE_STARTER_MONTHLY=
# NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=
# NEXT_PUBLIC_STRIPE_PRICE_ELITE_MONTHLY=

# Should match server STRIPE_PRO_TRIAL_DAYS for consistent Pro trial messaging (default 14; 0 = no trial copy).
# NEXT_PUBLIC_STRIPE_PRO_TRIAL_DAYS=14
