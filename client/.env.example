NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Must match server GOOGLE_CLIENT_ID (same Web OAuth client). Origins in Google Cloud must list this app URL (e.g. http://localhost:3000).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace_with_google_client_id.apps.googleusercontent.com

# Production: both URLs must be set before `next build` (absolute https origins, no trailing path).
# NEXT_PUBLIC_API_URL=https://api.example.com
# NEXT_PUBLIC_APP_URL=https://app.example.com
